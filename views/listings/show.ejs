<%- layout("./layouts/boilerplate.ejs") %>

<script>
  let mapapikey = "<%= process.env.MAP_API_KEY %>";
  let coordinates = <%- JSON.stringify(
    listelement.geometry && listelement.geometry.coordinates
      ? listelement.geometry.coordinates
      : []
  ) %>;
</script>

<div class="row">
  <div class="col-8 mt-3 offset-3">
    <h3><%=listelement.title%></h3>
    <h3>Owner Name : <%=listelement.owner.username%></h3>
  </div>

  <div class="card listing-card col-6 offset-3">
    <img
      src="<%=listelement.image.url%>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text"><i>Owner name :<%= listelement.owner.username%></i></p>
      <p><b><%=listelement.title%></b> </p>
        <p><%=listelement.description%></p>
        <p>&#8377;<%=listelement.price.toLocaleString("en-IN")%></p>
        <p><%=listelement.location%></p>
        <p><%=listelement.country%> </p>
    </div>
  </div>
</div>
<% if(currUser && listelement.owner._id.equals(currUser._id)){ %>
<div class="btns">
  <a
    href="/listings/edit/<%=listelement._id%>"
    class="btn dtn-dark show-edit-btn col-1 offset-3"
  >
    Edit</a
  >
  <br />
  <a
    href="/listings/delete/<%=listelement._id%>"
    class="btn dtn-dark show-delete-btn"
    >Delete</a
  >
</div>
<br />
<% } %>


<div class="col-6 offset-3 mb-5">
  <% if(currUser) { %>
  <h4>Give a Review</h4>
  <form
    action="/listings/reviews/<%=listelement._id%>"
    novalidate
    class="needs-validation"
    method="post"
  >
      <div class=" mt-3">
        <label for="rating" class="form-label"><h4>Rating</h4></label>
        <fieldset class="starability-slot">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
    <div class="mb-3">
      <label for="comment" class="form-label">Comment</label>
      <textarea
        name="review[comment]"
        class="form-control"
        cols="30"
        rows="5"
        required
      ></textarea>
      <div class="invalid-feedback">Comment is must</div>
    </div>
    <div class="mb-3">
      <label for="created_at" class="form-label">Created_At</label>
      <input type="text" class="form-control" name="review[created_at]" />
    </div>
    <button class="btn btn-outline-dark">Submit</button>
  </form>
  <hr />
  <% } %>

  <% if(listelement.reviews.length>0){ %>
  <p><b>All Reviews</b></p>

  <div class="row">
    <% for(let review of listelement.reviews){ %>
    <div class="card col-5 mb-3 ms-3">
      <div class="card-body">
        <h5 class="card-title">@<%=review.author.username%></h5>
        <p class="card-subtitle mb-2 text-body-secondary " style="font-size: 12px;">
          <%=review.created_at ? review.created_at.toLocaleString("en-IN", {
          day: "2-digit", month: "short", year: "numeric", hour: "2-digit",
          minute: "2-digit", hour12: false }) : "" %>
        </p>
        <p class="starability-result card-text small-stars"  data-rating="<%=review.rating%>"></p>
        <p class="card-text"><%=review.comment%></p>
        <p class="card-text">Rating: <%=review.rating%></p>
        <% if(currUser && currUser._id.equals(review.author._id)){ %>
        <form class="mb-3" method="POST" action="/listings/reviews/<%=listelement._id%>/<%=review._id%>?_method=DELETE">
          <button class="btn btn-outline-dark btn-sm">Delete</button>
        </form>
        <% } %>
      </div>
    </div>
    <%}%>
</div>
<% } %>
    <div class="row">
      <div class="col-12 mb-3">
         <h3>Where you'll be</h3>
         <p><b><%= listelement.location%>,<%= listelement.country%></b></p>
        <div id="map"></div>
      </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/map_display.js"></script>