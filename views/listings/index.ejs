<%- layout("./layouts/boilerplate.ejs") %>
<body>

  <div id="filters">
  
    <a href="/listings/filter/Trending"><div class="filter">
      <div>
        <i class="fa-solid fa-fire"></i>
      </div>
      <p>Trending</p>
    </div></a>
    
    
      <a href="/listings/filter/Rooms"><div class="filter">
        <div>
        <i class="fa-solid fa-bed"></i>
      </div>
      <p>Rooms</p>
    </div></a>
      
    
      <a href="/listings/filter/Pools"><div class="filter">
        <div>
        <i class="fa-solid fa-person-swimming"></i>
      </div>
      <p>Pools</p>
    </div></a>
      
      <a href="/listings/filter/Mountains"><div class="filter">
      <div>
        <i class="fa-solid fa-mountain"></i>
      </div>
      <p>Mountains</p>
    </div></a>
    
    <a href="/listings/filter/Beach"><div class="filter">
      <div>
        <i class="fa-solid fa-umbrella-beach"></i>
      </div>
      <p>Beach</p>
    </div></a>
    
    <a href="/listings/filter/Camping"> <div class="filter">
      <div>
        <i class="fa-solid fa-campground"></i>
      </div>
      <p>Camping</p>
    </div></a>
   
   <a href="/listings/filter/Farms"><div class="filter">
      <div>
        <i class="fa-solid fa-cow"></i>
      </div>
      <p>Farms</p>
    </div></a>
    
    <a href="/listings/filter/Arctic"><div class="filter">
      <div>
        <i class="fa-regular fa-snowflake"></i>
      </div>
      <p>Arctic</p>
    </div></a>

  <a href="/listings/filter/Scenic"><div class="filter">
      <div>
        <i class="fa-solid fa-mountain-sun"></i>
      </div>
      <p>Scenic</p>
    </div></a>

    <a href="/listings/filter/Tropic"><div class="filter">
      <div>
        <i class="fa-solid fa-sun"></i>
      </div>
      <p>Tropic</p>
    </div>
    </a>

    <div class="tax-toggle">
      <div class="form-switch form-check-reverse ">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
      <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
    </div>
    </div>
</div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
      <% for(let listing of alllisting){ %>
      <a href="/listings/show/<%=listing._id%>" class="listing-link">
        <div class="card cols listing-card">
        <img
          src="<%=listing.image.url%>"
          class="card-img-top"
          alt="listing_image"
          style="height: 20rem"
        />
        <div class="card-img-overlay">
          <i class="fa-regular fa-heart"></i>
        </div>
        <div class="card-body">
          <p class="card-text">
            <b><%=listing.title%></b> <br />
            #<%=listing.category%>
            &#8377;<%=listing.price.toLocaleString("en-IN")%> /night
            &nbsp;<i class="tax-info">+ &nbsp;18% GST</i>
          </p>
        </div>
      </div>
      </a>
      <%}%>
    </div>

    <a href="#" class="back-to-top" aria-label="Back to top">
  <i class="fa-solid fa-angle-up"></i>
  </a>
</body>

<script src="/js/index_script.js"></script>