<% if(success && success.length){ %>
       <div class="alert alert-success alert-dismissible fade show d-flex align-items-center col-6 offset-3" role="alert">
  <div class="flex-grow-1">
    <%= success %>
  </div>

  <button type="button"
          class="btn-close ms-2"
          data-bs-dismiss="alert"
          aria-label="Close">
  </button>
</div>   
<% } %>

<% if(secondary && secondary.length){ %>
         <div class="alert alert-secondary alert-dismissible fade show d-flex align-items-center col-6 offset-3" role="alert">
  <div class="flex-grow-1">
    <%= secondary %>
  </div>

  <button type="button"
          class="btn-close ms-2"
          data-bs-dismiss="alert"
          aria-label="Close">
  </button>
</div>
<% } %>

<% if(error && error.length){ %>
 <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center col-6 offset-3" role="alert">
  <div class="flex-grow-1">
    <%= error %>
  </div>

  <button type="button"
          class="btn-close ms-2"
          data-bs-dismiss="alert"
          aria-label="Close">
  </button>
</div>
<% } %>
